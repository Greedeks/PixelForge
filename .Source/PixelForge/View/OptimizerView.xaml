<UserControl x:Class="PixelForge.View.OptimizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:PixelForge.Core.Converters"
             xmlns:uc="clr-namespace:PixelForge.Assets.UserControls"
             xmlns:vm="clr-namespace:PixelForge.Core.ViewModel"
             xmlns:local="clr-namespace:PixelForge.View"
             mc:Ignorable="d" Style="{StaticResource LaunchPage}"
             d:DesignHeight="450" d:DesignWidth="800" AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver">
    <UserControl.Resources>
        <ResourceDictionary>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>
    <UserControl.DataContext>
        <vm:OptimizerViewModel/>
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition>
                <RowDefinition.Style>
                    <Style TargetType="RowDefinition">
                        <Setter Property="Height" Value="*"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasFiles}" Value="True">
                                <Setter Property="Height" Value="Auto"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RowDefinition.Style>
            </RowDefinition>

            <RowDefinition Height="Auto"/>

            <RowDefinition>
                <RowDefinition.Style>
                    <Style TargetType="RowDefinition">
                        <Setter Property="Height" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasFiles}" Value="True">
                                <Setter Property="Height" Value="*"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RowDefinition.Style>
            </RowDefinition>

            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="5" BorderThickness="1" CornerRadius="6" Cursor="Hand" MouseLeftButtonUp="OnDropZoneClick">
            <Border.BorderBrush>
                <DrawingBrush Viewport="0,0,8,8" ViewportUnits="Absolute" TileMode="Tile">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="{StaticResource Border_Hover_Card}">
                                <GeometryDrawing.Geometry>
                                    <GeometryGroup>
                                        <RectangleGeometry Rect="0,0,50,50" />
                                        <RectangleGeometry Rect="50,50,50,50" />
                                    </GeometryGroup>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Border.BorderBrush>
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="MinHeight" Value="80"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Background_Hover}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"  Margin="0,16">
                <TextBlock Text="{DynamicResource dropzone_Title}" Foreground="{StaticResource Inactive_Text}" FontSize="15" HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource dropzone_Sub}" Foreground="{StaticResource Inactive_Text}" FontSize="14" Margin="0,4,0,0" HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                    <Border Style="{StaticResource FormatBadge}">
                        <TextBlock Text="PNG"/>
                    </Border>
                    <Border Style="{StaticResource FormatBadge}">
                        <TextBlock Text="JPG"/>
                    </Border>
                    <Border Style="{StaticResource FormatBadge}">
                        <TextBlock Text="JPEG"/>
                    </Border>
                    <Border Style="{StaticResource FormatBadge}">
                        <TextBlock Text="WebP"/>
                    </Border>
                    <Border Style="{StaticResource FormatBadge}">
                        <TextBlock Text="SVG"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="5" Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{DynamicResource label_Files}" Foreground="{StaticResource Inactive_Text}" FontSize="11" VerticalAlignment="Center"/>

            <Rectangle Grid.Column="1" Height="1" Margin="8,0" VerticalAlignment="Center">
                <Rectangle.Fill>
                    <DrawingBrush Viewport="0,0,10,1" ViewportUnits="Absolute" TileMode="Tile" Stretch="None">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing>
                                <GeometryDrawing.Pen>
                                    <Pen Brush="{StaticResource Border_Default}" Thickness="1" DashStyle="{x:Static DashStyles.Dot}"/>
                                </GeometryDrawing.Pen>
                                <GeometryDrawing.Geometry>
                                    <LineGeometry StartPoint="0,0.5" EndPoint="10,0.5"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Style="{StaticResource OutlinedActionButton}" Command="{Binding SaveAllCommand}" Margin="0,0,6,0">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{StaticResource Icon_Save_All}" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource btn_SaveAll}" Foreground="#FFFFFF" FontSize="12"/>
                    </Grid>
                </Button>

                <Button Style="{StaticResource OutlinedActionButton}" Command="{Binding ProcessAllCommand}">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{StaticResource Icon_Hammer_Anvil}" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource btn_ProcessAll}" Foreground="#FFFFFF" FontSize="12"/>
                    </Grid>
                </Button>

                <Button Style="{StaticResource OutlinedActionButton}" Command="{Binding ClearAllCommand}">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0" Source="{StaticResource Icon_Remove}" Width="12" Height="12" Margin="0,0,6,0"/>
                        <TextBlock Grid.Column="1" Text="{DynamicResource btn_ClearAll}" Foreground="#FFFFFF" FontSize="12"/>
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="2" Margin="5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>

                <Grid Margin="0,4,0,6" Visibility="{Binding HasQueued, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource label_Queue}" Foreground="{StaticResource Inactive_Text}" FontSize="11" VerticalAlignment="Center"/>
                    <Rectangle Grid.Column="1" Height="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <Rectangle.Fill>
                            <DrawingBrush Viewport="0,0,10,1" ViewportUnits="Absolute" TileMode="Tile" Stretch="None">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="{StaticResource Border_Default}" Thickness="1" DashStyle="{x:Static DashStyles.Dot}"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <LineGeometry StartPoint="0,0.5" EndPoint="10,0.5"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>

                <ItemsControl ItemsSource="{Binding Cards}" Margin="0,0,0,12" Visibility="{Binding HasQueued, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <uc:FlowPanel HorizontalAlignment="Left" ContentAlignment="Stretch" Orientation="Vertical" HorizontalSpacing="10" VerticalSpacing="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDone}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <uc:FileCard
                                FileName="{Binding FileName}"
                                FileSizeBefore="{Binding FileSizeBefore}"
                                FileSizeAfter="{Binding FileSizeAfter}"
                                SavedPercent="{Binding SavedPercent}"
                                IsProcessing="{Binding IsProcessing}"
                                IsDone="{Binding IsDone}"
                                IsSaved="{Binding IsSaved}"
                                Thumbnail="{Binding Thumbnail}"
                                FilePath="{Binding FilePath}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,8,0,6" Visibility="{Binding HasDone, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource label_Processed}" Foreground="{StaticResource Inactive_Text}" FontSize="11" VerticalAlignment="Center"/>
                    <Rectangle Grid.Column="1" Height="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <Rectangle.Fill>
                            <DrawingBrush Viewport="0,0,10,1" ViewportUnits="Absolute" TileMode="Tile" Stretch="None">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="{StaticResource Border_Default}" Thickness="1" DashStyle="{x:Static DashStyles.Dot}"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <LineGeometry StartPoint="0,0.5" EndPoint="10,0.5"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>

                <ItemsControl ItemsSource="{Binding Cards}" Margin="0,0,0,12" Visibility="{Binding HasDone, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <uc:FlowPanel HorizontalAlignment="Left" ContentAlignment="Stretch" Orientation="Vertical" HorizontalSpacing="10" VerticalSpacing="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsDone}" Value="True"/>
                                        <Condition Binding="{Binding IsSaved}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <uc:FileCard
                                FileName="{Binding FileName}"
                                FileSizeBefore="{Binding FileSizeBefore}"
                                FileSizeAfter="{Binding FileSizeAfter}"
                                SavedPercent="{Binding SavedPercent}"
                                IsProcessing="{Binding IsProcessing}"
                                IsDone="{Binding IsDone}"
                                IsSaved="{Binding IsSaved}"
                                Thumbnail="{Binding Thumbnail}"
                                FilePath="{Binding FilePath}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Margin="0,8,0,6" Visibility="{Binding HasSaved, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{DynamicResource label_Saved}" Foreground="{StaticResource Inactive_Text}" FontSize="11" VerticalAlignment="Center"/>
                    <Rectangle Grid.Column="1" Height="1" Margin="8,0,0,0" VerticalAlignment="Center">
                        <Rectangle.Fill>
                            <DrawingBrush Viewport="0,0,10,1" ViewportUnits="Absolute" TileMode="Tile" Stretch="None">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="{StaticResource Border_Default}" Thickness="1" DashStyle="{x:Static DashStyles.Dot}"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <LineGeometry StartPoint="0,0.5" EndPoint="10,0.5"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>

                <ItemsControl ItemsSource="{Binding Cards}" Visibility="{Binding HasSaved, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <uc:FlowPanel HorizontalAlignment="Left" ContentAlignment="Stretch" Orientation="Vertical" HorizontalSpacing="10" VerticalSpacing="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSaved}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <uc:FileCard
                                FileName="{Binding FileName}"
                                FileSizeBefore="{Binding FileSizeBefore}"
                                FileSizeAfter="{Binding FileSizeAfter}"
                                SavedPercent="{Binding SavedPercent}"
                                IsProcessing="{Binding IsProcessing}"
                                IsDone="{Binding IsDone}"
                                IsSaved="{Binding IsSaved}"
                                Thumbnail="{Binding Thumbnail}"
                                FilePath="{Binding FilePath}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="3" Padding="10,8" Margin="5" Background="{StaticResource Background_Card}" CornerRadius="6" BorderBrush="{StaticResource Border_Hover}" BorderThickness="1" Visibility="{Binding HasFiles, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource stat_Processed}" Foreground="{StaticResource Inactive_Text}" FontSize="9" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding ProcessedText}" Foreground="{StaticResource Primary_Accent_Text}" FontSize="12" FontWeight="Medium"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="{DynamicResource stat_Saved}" Foreground="{StaticResource Inactive_Text}" FontSize="9" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding TotalSaved}" Foreground="{StaticResource Primary_Accent_Text}" FontSize="12" FontWeight="Medium" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Vertical" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{DynamicResource stat_AvgCompression}" Foreground="{StaticResource Inactive_Text}"  FontSize="9" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding AvgSavedPercent}" Foreground="{StaticResource Primary_Accent_Text}" FontSize="12" FontWeight="Medium" HorizontalAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
