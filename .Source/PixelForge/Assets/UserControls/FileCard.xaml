<UserControl x:Class="PixelForge.Assets.UserControls.FileCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:conv="clr-namespace:PixelForge.Core.Converters"
             xmlns:local="clr-namespace:PixelForge.Assets.UserControls"
             mc:Ignorable="d" x:Name="Root" IsTabStop="False" Focusable="False" KeyboardNavigation.TabNavigation="None"
             SnapsToDevicePixels="True" UseLayoutRounding="True" d:DesignHeight="72" d:DesignWidth="500" FontFamily="{StaticResource AA Stetica}">
    <UserControl.Resources>
        <ResourceDictionary>
            <conv:ImageToCheckerboardConverter x:Key="ImageToCheckerboard"/>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <conv:WaitingStateToVisibilityConverter x:Key="WaitingToVisibility"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Border CornerRadius="8" Opacity="0.5" Background="{StaticResource Brush_ShadowOverlay}" IsHitTestVisible="False">
            <Border.RenderTransform>
                <TranslateTransform X="3" Y="6"/>
            </Border.RenderTransform>
        </Border>

        <Border BorderThickness="1" CornerRadius="8" Padding="10">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource Background_Card}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Border_Default}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDone, ElementName=Root}" Value="True">
                            <Setter Property="Background" Value="{StaticResource Background_Card_Completed}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Border_Hover}"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Border_Hover_Card}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="6" ClipToBounds="True" VerticalAlignment="Center">
                    <Border.Background>
                        <MultiBinding Converter="{StaticResource ImageToCheckerboard}">
                            <Binding Path="Thumbnail" ElementName="Root"/>
                        </MultiBinding>
                    </Border.Background>
                    <Image Source="{Binding Thumbnail, ElementName=Root, TargetNullValue={StaticResource Icon_Image_Damaged}}" Stretch="UniformToFill"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="10,0" VerticalAlignment="Center">

                    <TextBlock Text="{Binding FileName, ElementName=Root}" Foreground="#FFFFFF" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>

                    <TextBlock Text="{Binding FileSizeBefore, ElementName=Root}" Foreground="{StaticResource Inactive_Text}" FontSize="11" Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProcessing, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsDone, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProcessing, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <StackPanel.Triggers>
                            <EventTrigger RoutedEvent="StackPanel.Loaded">
                                <BeginStoryboard>
                                    <Storyboard Timeline.DesiredFrameRate="120" RepeatBehavior="Forever">
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleY)">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.8"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot1" Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleX)">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.8"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:1.2" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>

                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2"  Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleY)" BeginTime="0:0:0.15">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.8"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:1.05" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot2" Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleX)" BeginTime="0:0:0.15">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.8"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:1.05" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>

                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleY)" BeginTime="0:0:0.3">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.8"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.9" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Dot3" Storyboard.TargetProperty="(Ellipse.RenderTransform).(ScaleTransform.ScaleX)" BeginTime="0:0:0.3">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.0" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.2" Value="1.8"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="1"/>
                                            <LinearDoubleKeyFrame KeyTime="0:0:0.9" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </StackPanel.Triggers>

                        <Ellipse x:Name="Dot1" Style="{StaticResource LoadingDot}"/>
                        <Ellipse x:Name="Dot2" Style="{StaticResource LoadingDot}"/>
                        <Ellipse x:Name="Dot3" Style="{StaticResource LoadingDot}"/>

                        <TextBlock Text="{DynamicResource stat_Processing}" Foreground="{StaticResource Inactive_Text}" FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Margin="0,3,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDone, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding FileSizeBefore, Mode=OneWay, ElementName=Root}" Foreground="{StaticResource Inactive_Text}"  FontSize="11"/>
                        <Run Text=" ➜ " Foreground="{StaticResource Inactive_Text}" FontSize="11"/>
                        <Run Text="{Binding FileSizeAfter, Mode=OneWay, ElementName=Root}" Foreground="{StaticResource Primary_Accent_Text}" FontSize="11"/>
                        <Run Text="{Binding SavedPercent, Mode=OneWay, ElementName=Root}" Foreground="{StaticResource Accent_Text}" FontSize="11"/>
                    </TextBlock>

                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">

                    <TextBlock Text="{Binding FileSizeBefore, ElementName=Root}" Foreground="{StaticResource Inactive_Text}" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsProcessing, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    
                    <Button Style="{StaticResource ProcessButton}" Margin="0,0,4,0" Command="{Binding DataContext.ProcessCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                        <Button.Visibility>
                            <MultiBinding Converter="{StaticResource WaitingToVisibility}">
                                <Binding Path="IsDone" RelativeSource="{RelativeSource AncestorType=local:FileCard}"/>
                                <Binding Path="IsProcessing" RelativeSource="{RelativeSource AncestorType=local:FileCard}"/>
                            </MultiBinding>
                        </Button.Visibility>
                        <Image Source="{StaticResource Icon_Hammer_Anvil}" Width="18" Height="18"/>
                    </Button>

                    <Button Margin="0,0,4,0" Command="{Binding DataContext.SaveCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SaveButton}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding IsDone, RelativeSource={RelativeSource AncestorType=local:FileCard}}" Value="True"/>
                                            <Condition Binding="{Binding IsSaved, RelativeSource={RelativeSource AncestorType=local:FileCard}}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Image Source="{StaticResource Icon_Save}" Width="18" Height="18"/>
                    </Button>

                    <Button Style="{StaticResource RemoveButton}" Command="{Binding DataContext.RemoveCardCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}">
                        <Image Source="{StaticResource Icon_Remove}" Width="18" Height="18"/>
                    </Button>

                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</UserControl>
